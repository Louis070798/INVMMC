# APP_ENV=production tren server that; APP_BASE_URL la URL cong khai nguoi dung
# truy cap (vd https://invmmc.congty.vn) - chi dung de hien thi, khong dung de
# forward Telegram (xem INTERNAL_WEBHOOK_BASE_URL ben duoi).
APP_ENV=local
APP_NAME=INVMMC Project Finance Control
APP_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./data/invmmc.db
REDIS_URL=redis://localhost:6379/0
UPLOAD_DIR=./data/uploads
DEMO_SEED_DATA=false

# scripts/telegram_polling.py doc bien nay de biet forward update Telegram vao
# dau. Bridge luon phai chay CUNG MAY voi backend (goi loopback noi bo, khong
# mo cong nao ra ngoai) - KHONG doi thanh domain cong khai, chi doi neu uvicorn
# chay port khac 8000 tren chinh may do.
INTERNAL_WEBHOOK_BASE_URL=http://127.0.0.1:8000

# Token .env chi dung MOT LAN de migrate thanh bot cua admin luc khoi dong dau
# tien; sau do moi nguoi dung tu dan token bot rieng o Settings. Co the de trong.
TELEGRAM_BOT_TOKEN=
# Doi gia tri moi khi deploy production, khong dung chung giua cac moi truong:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=

# Ollama PHAI duoc cai va chay TREN CHINH SERVER nay (khong tro ve may khac) -
# neu khong AI phan tich anh se loi ket noi khi may do tat.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_VISION_MODEL=qwen2.5vl:7b
AI_ENABLED=false
OWNER_ACCOUNT_NAMES=

MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn
MOMO_WEBHOOK_SECRET=

BANK_PROVIDER=vietqr
BANK_API_BASE_URL=
BANK_CLIENT_ID=
BANK_CLIENT_SECRET=
BANK_WEBHOOK_SECRET=

# Doi gia tri moi khi deploy production (xem lenh sinh secret o tren):
JWT_SECRET=change-me-in-local-only

# Email quen mat khau. De trong SMTP_HOST khi dev/test: link reset se duoc
# log ra console thay vi gui that. Vi du dung Gmail: smtp.gmail.com, port 587,
# SMTP_USERNAME la dia chi gmail, SMTP_PASSWORD la App Password (khong phai
# mat khau dang nhap Gmail thuong - tao tai myaccount.google.com/apppasswords).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=INVMMC Finance
SMTP_USE_TLS=true

# Doi ADMIN_PASSWORD truoc khi deploy production, hoac dang nhap xong doi ngay.
ADMIN_EMAIL=admin@invmmc.local
ADMIN_PASSWORD=Admin@123456
ADMIN_FULL_NAME=System Admin
ADMIN_ROLES=system_admin,cfo,finance_manager,auditor
